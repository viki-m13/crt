{
  "version": 2,
  "builds": [
    {
      "src": "api/analyze.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "250mb", "excludeFiles": "{experiments/**,max/**,short/**,crypto/**,docs/**}" }
    },
    {
      "src": "docs/**",
      "use": "@vercel/static"
    },
    {
      "src": "experiments/docs/**",
      "use": "@vercel/static"
    },
    {
      "src": "max/docs/**",
      "use": "@vercel/static"
    },
    {
      "src": "crypto/docs/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/analyze.py" },
    { "src": "/short$", "status": 308, "headers": { "Location": "/max/" } },
    { "src": "/short/(.*)", "status": 308, "headers": { "Location": "/max/$1" } },
    { "src": "/crypto$", "status": 308, "headers": { "Location": "/experiments/#crypto" } },
    { "src": "/crypto/(.*)", "status": 308, "headers": { "Location": "/experiments/#crypto" } },
    { "src": "/max/(.*)", "dest": "/max/docs/$1" },
    { "src": "/experiments/(.*)", "dest": "/experiments/docs/$1" },
    { "src": "/(.*)", "dest": "/docs/$1" }
  ]
}
