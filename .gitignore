__pycache__/
*.pyc

# Cached market data and intermediate arrays (large, regenerated on demand)
experiments/data/
*.npy
crypto/src/data/

# v8 research: large rebuilt panel + retrained predictions (regenerable)
experiments/monthly_dca/v8/panel_v8.parquet
experiments/monthly_dca/v8/ml_preds_v8.parquet

# Regen backups and run logs
*.bak
max/research/*.log
max/research/fetch_new_log.txt

# v8 weekly track — features panel is 337MB, regenerable from
# experiments/monthly_dca/v8/weekly/build_weekly_features.py.
# Keep weekly_preds.parquet (7MB, the actual GBM walk-forward output)
# and the small membership/SPY caches.
experiments/monthly_dca/v8/weekly/cache/features_weekly.parquet

# Agent worktrees (internal state from parallel research subagents)
.claude/

# CreditFloor: large per-run audit dump is regenerable; keep only lean signals
strategies/credit_spread/results/research_full.json

# FNSPID raw dataset (641 MB Hugging Face zip + per-ticker CSV extracts).
# Re-downloaded on demand by experiments/monthly_dca/v5/spx_pit/build_sp500_pit_prices.py
# from https://huggingface.co/datasets/Zihan1004/FNSPID
experiments/monthly_dca/cache/v2/sp500_pit/fnspid/

# Augmented PIT-S&P-500 features (~350 month-end parquet files, regenerable
# from experiments/monthly_dca/v5/spx_pit/cache_features_pit.py + the augmented
# daily panel). Excluded to keep the branch small during the multi-phase
# rebuild; the final summary metrics (the actual validation outputs) ARE
# committed.
experiments/monthly_dca/cache/v2/sp500_pit/augmented/features/

# Augmented panel_cross_section_v3 (~244 MB; exceeds GitHub's 100 MB hard
# limit). Regenerable from augmented features + monthly returns via
# experiments/monthly_dca/v5/spx_pit/build_panel_pit.py.
experiments/monthly_dca/cache/v2/sp500_pit/augmented/panel_cross_section_v3.parquet

# Python virtualenv (local research env)
.venv/

# CreditFloor v3 full-history price panel (rebuilt from yfinance every
# scan; ~1 GB of JSON) and replay row tables (regenerable via replay.py).
strategies/credit_spread/cache_full/
strategies/credit_spread/results/replay_rows*.csv.gz
strategies/credit_spread/results/breadth_full.json
strategies/credit_spread/results/feature_rows.npz
strategies/credit_spread/results/sigma_distance_rows.npz
